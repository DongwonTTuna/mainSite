{
  "name": "mainsite",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "#application/*": "./src/lib/application/*.ts",
    "#domain/*": "./src/lib/domain/*.ts",
    "#generated/*": "./src/generated/*.js",
    "#infrastructure/*": "./src/lib/infrastructure/*.ts",
    "#presentation/*": "./src/lib/presentation/*"
  },
  "scripts": {
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/generated/paraglide --strategy url cookie baseLocale",
    "dev": "bun run paraglide:compile && vite dev",
    "build": "bun run paraglide:compile && vite build",
    "preview": "bun run paraglide:compile && vite preview",
    "prepare": "bun run paraglide:compile && svelte-kit sync || echo ''",
    "check": "bun run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@inlang/paraglide-js": "^2.5.0",
    "@internationalized/date": "^3.10.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.48.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/three": "^0.181.0",
    "bits-ui": "^2.14.3",
    "clsx": "^2.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.0",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "svelte": "^5.43.7",
    "svelte-check": "^4.3.4",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2",
    "vite-imagetools": "^9.0.0",
    "bun-types": "^1.3.10"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "gsap": "^3.13.0",
    "ogl": "^1.0.11"
  }
}
