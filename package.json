{
  "name": "mainsite",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "#application/*": "./src/lib/application/*.ts",
    "#domain/*": "./src/lib/domain/*.ts",
    "#infrastructure/*": "./src/lib/infrastructure/*.ts",
    "#presentation/*": "./src/lib/presentation/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "update": "bunx npm-check-updates -u",
    "verify": "bun run check && bun run lint && bun run test && bun run build",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "bun-types": "^1.3.11",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-imagetools": "^10.0.0"
  },
  "packageManager": "bun@1.3.10"
}
